# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Cloud-backed filesystem sync tool"
maintainer: ["Romain Beauxis <toots@rastageeks.org>"]
authors: ["Romain Beauxis <toots@rastageeks.org>"]
license: "MIT"
homepage: "https://github.com/toots/tsync"
bug-reports: "https://github.com/toots/tsync/issues"
depends: [
  "ocaml" {>= "5.5.0"}
  "dune" {>= "3.23"}
  "yojson"
  "lwt_domain"
  "lwt"
  "lwt_ppx"
  "cmdliner"
  "odoc" {with-doc}
]
depopts: ["syslog" "tsync-s3" "tsync-fuse"]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
x-maintenance-intent: ["(latest)"]
depexts: [
  ["libxxhash-dev"] {os-family = "debian"}
  ["xxhash-devel"] {os-distribution = "fedora"}
]
