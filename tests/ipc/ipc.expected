########## LISTING ##########
=== files: dirty then clean etag
  write a.txt "hello"
  write b.txt "world"
--- listing
  list_dir tsync/test/ -> {"ok":true,"dirs":[],"files":[{"key":"tsync/test/a.txt","size":5,"mtime":"<mtime>","etag":"cfc4edca0bdce7a2"},{"key":"tsync/test/b.txt","size":5,"mtime":"<mtime>","etag":"9180bf84fb8e7cab"}]}
  list_all tsync/test/ -> {"ok":true,"files":[{"key":"tsync/test/a.txt","size":5,"mtime":"<mtime>","etag":"cfc4edca0bdce7a2"},{"key":"tsync/test/b.txt","size":5,"mtime":"<mtime>","etag":"9180bf84fb8e7cab"}]}

=== nested directories keyed as full paths
  mkdir sub
  drain
  write sub/c.txt "nested"
  write top.txt "top"
--- listing
  list_dir tsync/test/ -> {"ok":true,"dirs":["tsync/test/sub/"],"files":[{"key":"tsync/test/top.txt","size":3,"mtime":"<mtime>","etag":"a0a8ff66a5d845b0"}]}
  list_dir tsync/test/sub/ -> {"ok":true,"dirs":[],"files":[{"key":"tsync/test/sub/c.txt","size":6,"mtime":"<mtime>","etag":"872c93b4f32e2aaa"}]}
  list_all tsync/test/ -> {"ok":true,"files":[{"key":"tsync/test/sub/c.txt","size":6,"mtime":"<mtime>","etag":"872c93b4f32e2aaa"},{"key":"tsync/test/top.txt","size":3,"mtime":"<mtime>","etag":"a0a8ff66a5d845b0"}]}

=== identical content shares an etag
  write x.txt "same bytes"
  drain
  write y.txt "same bytes"
--- listing
  list_dir tsync/test/ -> {"ok":true,"dirs":[],"files":[{"key":"tsync/test/x.txt","size":10,"mtime":"<mtime>","etag":"bb52b673b2fffd64"},{"key":"tsync/test/y.txt","size":10,"mtime":"<mtime>","etag":"bb52b673b2fffd64"}]}
  list_all tsync/test/ -> {"ok":true,"files":[{"key":"tsync/test/x.txt","size":10,"mtime":"<mtime>","etag":"bb52b673b2fffd64"},{"key":"tsync/test/y.txt","size":10,"mtime":"<mtime>","etag":"bb52b673b2fffd64"}]}

########## CHANGES ##########
=== foreign put
  A: write a.txt "hi"
  A: drain
--- B changes_since (A's ops are foreign to B)
  changes_since from baseline (working) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[{"op":"put","key":"tsync/test/a.txt","size":2}]}
  changes_since from current (up to date) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[]}
  changes_since from pruned anchor (stale) -> {"ok":true,"stale":true}

=== foreign mkdir then put
  A: mkdir sub
  A: drain
  A: write sub/f.txt "deep"
  A: drain
--- B changes_since (A's ops are foreign to B)
  changes_since from baseline (working) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[{"op":"mkdir","key":"tsync/test/sub/"},{"op":"put","key":"tsync/test/sub/f.txt","size":4}]}
  changes_since from current (up to date) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[]}
  changes_since from pruned anchor (stale) -> {"ok":true,"stale":true}

=== foreign delete
  A: write a.txt "x"
  A: drain
  A: delete a.txt
  A: drain
--- B changes_since (A's ops are foreign to B)
  changes_since from baseline (working) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[{"op":"put","key":"tsync/test/a.txt","size":1},{"op":"delete","key":"tsync/test/a.txt"}]}
  changes_since from current (up to date) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[]}
  changes_since from pruned anchor (stale) -> {"ok":true,"stale":true}

=== foreign rename
  A: write a.txt "x"
  A: drain
  A: rename a.txt -> b.txt
  A: drain
--- B changes_since (A's ops are foreign to B)
  changes_since from baseline (working) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[{"op":"put","key":"tsync/test/a.txt","size":1},{"op":"rename","key":"tsync/test/b.txt","src":"tsync/test/a.txt","is_dir":false}]}
  changes_since from current (up to date) -> {"ok":true,"stale":false,"cursor":"<cursor>","ops":[]}
  changes_since from pruned anchor (stale) -> {"ok":true,"stale":true}

