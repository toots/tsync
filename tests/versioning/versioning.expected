  file b.txt = manifest size=9 chunks=1

=== revert a deleted file (dataless)
  write foo.txt "deleted content"
  drain
  delete foo.txt
  revert foo.txt @latest
--- tree
  f foo.txt size=15 cached=false uploaded=true etag=eadad83fb0989511
--- content
  foo.txt = "deleted content"
--- backend
  chunk d1a9d4d84e18e087-2a474494f098b599 size=15
  cursor = <entry-3>
  journal <entry-1> = put foo.txt 15
  journal <entry-2> = delete foo.txt
  journal <entry-3> = put foo.txt 15
  version foo.txt#1 = manifest size=15 chunks=1
  file foo.txt = manifest size=15 chunks=1

=== revert a modified file to its previous version
  write foo.txt "one"
  drain
  write foo.txt "two"
  drain
  write foo.txt "three"
  drain
  revert foo.txt @latest
--- tree
