=== modify keeps prior versions
  write foo.txt "one"
  drain
  write foo.txt "two two"
  drain
  write foo.txt "three three three"
  drain
--- tree
  f foo.txt size=17 cached=true uploaded=true etag=bc9c9f6403fc0d62
--- content
  foo.txt = "three three three"
--- backend
  chunk 3ab8997bc73098ac-74d584d55f333769 size=7
  chunk 911faba7321fe1a0-a3cf92cbf55153da size=3
  chunk faf60158c5948cd2-60f690e9588d51bd size=17
  journal <entry-1> = put foo.txt 3
  journal <entry-2> = put foo.txt 7
  journal <entry-3> = put foo.txt 17
  version foo.txt#1 = manifest size=3 chunks=1
  version foo.txt#2 = manifest size=7 chunks=1
  file foo.txt = manifest size=17 chunks=1

