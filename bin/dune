(executable
 (name tsync)
 (modules tsync)
 (public_name tsync)
 (libraries
  tsync_core
  tsync_conf
  tsync_queue
  tsync_file
  tsync_s3_client
  tsync_log
  tsync_runtime
  cmdliner
  threads.posix
  unix))

(library
 (name tsync_runtime)
 (wrapped false)
 (modules runtime)
 (libraries
  tsync_conf
  tsync_file
  tsync_queue
  (select
   runtime.ml
   from
   (tsync_fuse -> runtime.fuse.ml)
   (tsync_file_provider -> runtime.file_provider.ml)
   (-> runtime.noop.ml))))
